{
  "name": "@djt-aslan/agent-teams",
  "version": "0.1.0",
  "description": "AI Agent Teams for end-to-end software delivery",
  "directories": {
    "doc": "docs"
  },
  "bin": {
    "agent-teams": "dist/bundle.cjs"
  },
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "node -e \"require('esbuild').buildSync({ entryPoints: ['src/index.ts'], bundle: true, platform: 'node', outfile: 'dist/bundle.cjs', external: ['yaml'], format: 'cjs' })\"",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "keywords": [],
  "files": [
    "dist/bundle.cjs",
    "defaults/",
    "README.md"
  ],
  "author": "",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
